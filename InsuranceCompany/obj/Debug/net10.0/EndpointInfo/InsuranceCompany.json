  "components": {
    "schemas": {
      "AddOnCreateDto": {
        "required": [
          "additionalCost",
          "addOnName"
        ],
        "type": "object",
        "properties": {
          "addOnName": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "description": {
            "maxLength": 500,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "additionalCost": {
            "minimum": 0,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "AddOnUpdateDto": {
        "required": [
          "additionalCost",
          "addOnName"
        ],
        "type": "object",
        "properties": {
          "addOnName": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "description": {
            "maxLength": 500,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "additionalCost": {
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "isActive": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "ClaimFileDto": {
        "required": [
          "estimatedLossAmount",
          "incidentDate",
          "incidentDescription",
          "issuedPolicyId"
        ],
        "type": "object",
        "properties": {
          "issuedPolicyId": {
            "type": "integer",
            "format": "int32"
          },
          "estimatedLossAmount": {
            "maximum": 10000000,
            "minimum": 1,
            "type": "number",
            "format": "double"
          },
          "incidentDescription": {
            "maxLength": 1000,
            "minLength": 10,
            "type": "string"
          },
          "incidentDate": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "ClaimReviewDto": {
        "required": [
          "officerRemarks",
          "status"
        ],
        "type": "object",
        "properties": {
          "status": {
            "minLength": 1,
            "pattern": "Approved|Rejected",
            "type": "string"
          },
          "approvedSettlementAmount": {
            "maximum": 10000000,
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "officerRemarks": {
            "maxLength": 500,
            "minLength": 5,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "PaymentProcessDto": {
        "required": [
          "paymentMethod",
          "proposalId",
          "transactionId"
        ],
        "type": "object",
        "properties": {
          "proposalId": {
            "type": "integer",
            "format": "int32"
          },
          "paymentMethod": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string"
          },
          "transactionId": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "PolicyCreateDto": {
        "required": [
          "basePremium",
          "categoryId",
          "coverageAmount",
          "description",
          "policyDurationMonths",
          "policyName",
          "policyType"
        ],
        "type": "object",
        "properties": {
          "policyName": {
            "minLength": 1,
            "type": "string"
          },
          "description": {
            "maxLength": 500,
            "minLength": 0,
            "type": "string"
          },
          "basePremium": {
            "type": "number",
            "format": "double"
          },
          "coverageAmount": {
            "type": "number",
            "format": "double"
          },
          "policyDurationMonths": {
            "type": "integer",
            "format": "int32"
          },
          "policyType": {
            "minLength": 1,
            "pattern": "^(Comprehensive|Third-Party, Fire & Theft TPFT|Third-Party Only TPO)$",
            "type": "string"
          },
          "categoryId": {
            "type": "integer",
            "format": "int32"
          },
          "associatedAddOnIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PolicyUpdateDto": {
        "required": [
          "basePremium",
          "coverageAmount",
          "description",
          "policyDurationMonths",
          "policyName",
          "policyType"
        ],
        "type": "object",
        "properties": {
          "policyName": {
            "minLength": 1,
            "type": "string"
          },
          "description": {
            "maxLength": 500,
            "minLength": 0,
            "type": "string"
          },
          "basePremium": {
            "type": "number",
            "format": "double"
          },
          "coverageAmount": {
            "type": "number",
            "format": "double"
          },
          "policyDurationMonths": {
            "type": "integer",
            "format": "int32"
          },
          "policyType": {
            "minLength": 1,
            "pattern": "^(Comprehensive |Third-Party, Fire & Theft (TPFT)| Third-Party Only (TPO))",
            "type": "string"
          },
          "isActive": {
            "type": "boolean"
          },
          "categoryId": {
            "type": "integer",
            "format": "int32"
          },
          "associatedAddOnIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ProposalCreateDto": {
        "required": [
          "chassisNumber",
          "engineNumber",
          "policyId",
          "vehicleMake",
          "vehicleModel",
          "vehicleNumber",
          "vehicleYear"
        ],
        "type": "object",
        "properties": {
          "policyId": {
            "type": "integer",
            "format": "int32"
          },
          "vehicleNumber": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string"
          },
          "vehicleMake": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string"
          },
          "vehicleModel": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string"
          },
          "vehicleYear": {
            "maximum": 2100,
            "minimum": 1900,
            "type": "integer",
            "format": "int32"
          },
          "engineNumber": {
            "maxLength": 25,
            "minLength": 0,
            "type": "string"
          },
          "chassisNumber": {
            "maxLength": 25,
            "minLength": 0,
            "type": "string"
          },
          "selectedAddOnIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ProposalReviewDto": {
        "required": [
          "officerRemarks",
          "status"
        ],
        "type": "object",
        "properties": {
          "status": {
            "minLength": 1,
            "pattern": "^(Approved|Rejected)$",
            "type": "string"
          },
          "officerRemarks": {
            "maxLength": 500,
            "minLength": 0,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "UserLoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UserRegisterDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          },
          "phone": {
            "type": "string",
            "nullable": true
          },
          "aadhaarNumber": {
            "type": "string",
            "nullable": true
          },
          "age": {
            "type": "integer",
            "format": "int32"
          },
          "panNumber": {
            "type": "string",
            "nullable": true
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date-time"
          },
          "roleId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Enter your JWT token. Example: eyJhbGci...",
        "scheme": "Bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
}